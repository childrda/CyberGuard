APP_NAME=CyberGuard
APP_ENV=local
APP_KEY=
# In production: set to false. Never enable debug on a public server.
APP_DEBUG=true
# Base URL for the app. For dev boxes that are not publicly reachable, keep this as your
# local URL and set PHISHING_PUBLIC_URL below so links/images in sent emails work.
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_MAINTENANCE_DRIVER=file

# Phishing awareness platform (authorized internal testing only)
PHISHING_SIMULATION_ENABLED=false
GMAIL_REPORT_ADDON_ENABLED=true
# Allowed domains are configured per tenant (Settings → Edit tenant). Leave empty.
# PHISHING_ALLOWED_DOMAINS=example.com
PHISHING_FROM_DOMAIN=example.com
# When APP_URL is not reachable by recipients (e.g. dev on 172.17.x.x), set this to a
# URL they can reach: ngrok/Cloudflare Tunnel URL or staging. Emails will use it for
# tracking links, tracking pixel, and asset URLs. Leave unset to use APP_URL.
# PHISHING_PUBLIC_URL=https://your-tunnel.ngrok.io
PHISHING_WEBHOOK_SECRET=
PHISHING_WEBHOOK_DEBUG_SIGNATURE=false
PHISHING_OPEN_TRACKING=true
PHISHING_GMAIL_REMOVAL_ENABLED=false
PHISHING_SLACK_QUEUE=notifications

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cyberguard
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=

QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Mail: "log" writes to storage/logs (no real email). Use "smtp" + credentials to send real email (e.g. password reset).
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_URL=smtp://user:pass@smtp.example.com:587

# Gmail removal (trash confirmed phishing from mailboxes)
# Store service account JSON outside web root. Do not commit.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_WORKSPACE_DOMAIN=yourdomain.com
# GOOGLE_ADMIN_USER=admin@yourdomain.com

# Production seeding: db:seed throws in production unless SEEDER_ALLOW_PRODUCTION=true
# SEEDER_ALLOW_PRODUCTION=
# When seeding in production, set a strong password (UserSeeder skips if unset or "password")
# SEEDER_DEFAULT_PASSWORD=
